# Copy this file to .env and fill with your credentials

# Database
DB_HOST=sqlserver
DB_PORT=1433
DB_NAME=phlab_subscriptionportal
DB_USER=sa
DB_PASSWORD=change_this_database_password

# JWT
JWT_SECRET=change_this_secret_for_prod

# App URL (publicly reachable base URL for webhooks/back urls)
APP_URL=http://localhost:8000

# Mercado Pago (use TEST credentials)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_NOTIFICATION_URL=

# S3 / MinIO course files
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=us-east-1
S3_USE_SSL=true

# External identity provider.
# SECURITY_PROVIDER currently supports auth0 in the frontend adapter.
# Backend token validation is generic OpenID Connect and can validate Auth0, Okta or Entra ID.
SECURITY_PROVIDER=auth0
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=
OIDC_JWKS_URL=
OIDC_USERINFO_URL=
OIDC_ALGORITHMS=RS256

# Auth0 fallback compatibility
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_AUDIENCE=

# Provider examples:
# Auth0 issuer: https://your-tenant.auth0.com/
# Okta issuer: https://your-domain.okta.com/oauth2/default
# Entra ID issuer: https://login.microsoftonline.com/YOUR_TENANT_ID/v2.0
